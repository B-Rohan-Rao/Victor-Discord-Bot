# Groq LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Search API Configuration
SERPER_API_KEY=your_serper_api_key_here

# Cache Configuration
CACHE_TTL=2592000  # 30 days in seconds

# Redis Configuration (primary cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MongoDB Configuration (persistent backing store)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=autonomous_research_agent
MONGO_COLLECTION=research_results

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/your_webhook_id/your_webhook_token
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=

# Web Scraping Configuration
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
REQUEST_TIMEOUT=10
MAX_RETRIES=3

# Search Configuration
MAX_SEARCH_RESULTS=5
PREFERRED_SOURCES=academic,news,official

# Application Configuration
LOG_LEVEL=INFO
DEBUG_MODE=False
MAX_CONCURRENT_QUERIES=5
HALLUCINATION_THRESHOLD=0.75  # Confidence threshold for flagging hallucinations

# Subscription/Scheduler Configuration
MAX_SUBSCRIPTIONS_PER_USER=20
SUBSCRIPTION_EXPIRY_DAYS=60
SCHEDULER_BATCH_SIZE=20
SCHEDULER_BATCH_DELAY_SECONDS=3.0
ADMIN_USER_ID=
UPDATE_CHECK_DAYS=7
BOT_INSTANCE_NAME=Local
